{
  "name": "knowledge-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/ir",
    "packages/compiler",
    "packages/data",
    "packages/sync",
    "packages/runtime",
    "packages/query-server",
    "packages/components",
    "packages/renderers/web",
    "packages/renderers/slides",
    "apps/studio",
    "apps/site"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@knowledge/studio",
    "read": "npm run dev --workspace=@knowledge/site",
    "gateway": "tsx packages/query-server/src/server.ts",
    "export:slidev": "tsx scripts/export-slidev.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:content": "tsx scripts/check-content.ts",
    "build:site": "npm run check:content && npm run build --workspace=@knowledge/site"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
